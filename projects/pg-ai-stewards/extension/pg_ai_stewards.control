comment = 'pg-ai-stewards: AI agent state, memory, and pipelines as Postgres rows'
default_version = '0.2.0'
module_pathname = '$libdir/pg_ai_stewards'
relocatable = false
schema = 'stewards'
superuser = true
trusted = false
# pgvector ships the vector(N) type used by brain_entries.embedding and
# messages.embedding. Postgres will create it transitively if missing.
requires = 'vector'
