# pg-ai-stewards — provider/secret bootstrap shape
#
# Copy to `.env` and fill in real values. `.env` is gitignored;
# this file is the committed shape reference. The bgworker reads
# these on startup and builds an in-memory provider registry.
# See proposal.md § "Provider abstraction and secrets".
#
# Naming: STEWARDS_PROVIDER_<NAME>_<FIELD>
#   <NAME>  = uppercase-snake friendly id (becomes lowercase in SQL)
#   <FIELD> = BASE_URL | API_KEY | DEFAULT_MODEL | KIND
#
# KIND defaults to "openai" (i.e. OpenAI-compatible chat/completions
# and embeddings). "anthropic" is reserved for Phase 2+ (MiniMax M2.x).

# ---------------------------------------------------------------
# Postgres superuser (matches docker-compose.yaml defaults)
# ---------------------------------------------------------------
POSTGRES_USER=stewards
POSTGRES_PASSWORD=stewards
POSTGRES_DB=stewards

# ---------------------------------------------------------------
# Ollama — local, free. Used for embeddings and free local chat.
# Default model = nomic-embed-text-v1.5 to match gospel-engine-v2.
# Pull it first:  ollama pull nomic-embed-text:v1.5
# ---------------------------------------------------------------
STEWARDS_PROVIDER_OLLAMA_BASE_URL=http://host.docker.internal:11434/v1
STEWARDS_PROVIDER_OLLAMA_API_KEY=ollama
STEWARDS_PROVIDER_OLLAMA_DEFAULT_MODEL=nomic-embed-text:v1.5
STEWARDS_PROVIDER_OLLAMA_KIND=openai

# ---------------------------------------------------------------
# LM Studio — local, free. OpenAI-compat shim.
# Start LM Studio's local server first; it picks port 1234 by default.
# The API key is a placeholder; LM Studio ignores it but most OpenAI
# clients refuse to send a request without one.
# ---------------------------------------------------------------
STEWARDS_PROVIDER_LM_STUDIO_BASE_URL=http://host.docker.internal:1234/v1
STEWARDS_PROVIDER_LM_STUDIO_API_KEY=lm-studio
STEWARDS_PROVIDER_LM_STUDIO_DEFAULT_MODEL=qwen/qwen3.6-27b
STEWARDS_PROVIDER_LM_STUDIO_KIND=openai

# ---------------------------------------------------------------
# OpenCode Go — paid, $10/mo subscription. Kimi K2.6, GLM-5.1, etc.
# Get the bearer key from https://opencode.ai/auth (Go subscription).
# Endpoint and model ids per https://opencode.ai/docs/go/ .
# ---------------------------------------------------------------
STEWARDS_PROVIDER_OPENCODE_GO_BASE_URL=https://opencode.ai/zen/go/v1
STEWARDS_PROVIDER_OPENCODE_GO_API_KEY=
STEWARDS_PROVIDER_OPENCODE_GO_DEFAULT_MODEL=kimi-k2.6
STEWARDS_PROVIDER_OPENCODE_GO_KIND=openai

# OpenCode ZEN — pay-per-use tier (ZEN.1, 2026-05-31). SAME api key as go.
# Hosts the real Anthropic Claude models (claude-opus-4-8/4-7/4-6, sonnet-4-6,
# haiku-4-5) via /zen/v1/messages (Anthropic format — substrate dispatches it
# per model_capability.api_format='anthropic'), plus -free models + gpt-5.x.
# ENFORCED $18 spend cap lives in stewards.provider_spend_caps, not here.
STEWARDS_PROVIDER_OPENCODE_ZEN_BASE_URL=https://opencode.ai/zen/v1
STEWARDS_PROVIDER_OPENCODE_ZEN_API_KEY=
STEWARDS_PROVIDER_OPENCODE_ZEN_DEFAULT_MODEL=claude-haiku-4-5
STEWARDS_PROVIDER_OPENCODE_ZEN_KIND=openai

# ---------------------------------------------------------------
# Google Gemini — paid, per-use. gemini-3.5-flash, gemini-3-pro-preview,
# gemini-2.5-{pro,flash,flash-lite}, etc.
# Get the API key from Google Cloud Console; enable the Gemini API.
# IMPORTANT: use the OpenAI-COMPAT base URL (.../v1beta/openai) — the
# substrate posts to {base_url}/chat/completions, and Gemini's
# OpenAI-compatible endpoint lives under /openai. The bare /v1beta/
# path 404s. Pass bare model ids (e.g. gemini-2.5-flash, no "models/"
# prefix). Model list: GET {base_url}/models with the bearer key.
# ---------------------------------------------------------------
STEWARDS_PROVIDER_GOOGLE_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
STEWARDS_PROVIDER_GOOGLE_GEMINI_API_KEY=
STEWARDS_PROVIDER_GOOGLE_GEMINI_KIND=openai

# ---------------------------------------------------------------
# Bridge daemon (docker-compose service `bridge`) — outbound MCP
# server tokens. The bridge resolves $$env: / $env: placeholders in
# stewards.mcp_servers.env against these process-env vars at
# subprocess spawn time. URLs are passed through to the spawned
# server processes (gospel-mcp, becoming-mcp).
# ---------------------------------------------------------------
GOSPEL_ENGINE_URL=https://engine.ibeco.me
GOSPEL_ENGINE_TOKEN=
BECOMING_URL=https://ibeco.me
BECOMING_TOKEN=

# ---------------------------------------------------------------
# (Phase 2+) Master key for pgcrypto-encrypted secrets in
# stewards.providers. Leave unset until env-var-only friction shows up.
# ---------------------------------------------------------------
# STEWARDS_MASTER_KEY=
