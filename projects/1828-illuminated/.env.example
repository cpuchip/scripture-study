# 1828-illuminated — example environment
# Copy to .env and fill in real values. The .env file is gitignored.
#
# Phase-by-phase shape: variables below are grouped by which compose service
# reads them and which phase of the backend pivot introduces them. Phase 1
# only needs DB + healthchecks; LLM/Thummim variables fire later.

# ───────────────────────────────────────────────────────────────────────────
# Phase 1 — required from day one
# ───────────────────────────────────────────────────────────────────────────

# Postgres (db service)
# Generate a long random password; Postgres needs it before booting.
# Production: set in Dokploy's env-vars UI, not in a file.
POSTGRES_PASSWORD=replace-me-with-a-long-random-string

# Backend convenience (constructed from POSTGRES_PASSWORD; you usually
# don't need to override this — compose builds it for you)
# DATABASE_URL=postgres://i1828:${POSTGRES_PASSWORD}@db:5432/i1828?sslmode=disable

# ───────────────────────────────────────────────────────────────────────────
# Phase 4 — LLM proxy + BYOK sessions
# ───────────────────────────────────────────────────────────────────────────

# Provider for the SERVER's default key (optional). If unset, /api/llm/render
# requires a reader-provided BYOK session. Recommended: leave the server
# default unset in production and let readers bring their own key.
# Supported: openai | openrouter | opencode-go | opencode-zen | mock
LLM_PROVIDER=mock

# When LLM_PROVIDER is set to a real provider, these configure the server's
# default key path:
# LLM_BASE_URL=https://opencode.example/v1
# LLM_API_KEY=
# LLM_MODEL=

# Michael's opencode-go key (used by the backend if LLM_PROVIDER=opencode-go
# AND no BYOK session is present). Lives in projects/1828-illuminated/.env
# at the project root (gitignored). Copy from there for local backend dev.
# In Dokploy production this is set in the UI.
OPENCODE_GO_API_KEY=

# BYOK session model
LLM_PROXY_ENABLED=true
LLM_BYOK_ENABLED=true
LLM_SESSION_TTL_HOURS=24
LLM_SESSION_SLIDING_WINDOW=true

# Caps (D-LP-3, D-LP-4 — server default key, not BYOK sessions)
LLM_RATE_PER_IP_PER_MIN=10
LLM_RATE_PER_IP_PER_DAY=1000
LLM_GLOBAL_TOKEN_CAP_PER_DAY=200000
LLM_MAX_TOKENS_DEFAULT=800
LLM_MAX_TOKENS_HARD=1500
LLM_TEMPERATURE_DEFAULT=0.3
LLM_TEMPERATURE_HARD=0.7
LLM_TIMEOUT_SECONDS=60

# ───────────────────────────────────────────────────────────────────────────
# Phase 3 — dictionary lazy fetch
# ───────────────────────────────────────────────────────────────────────────

# Daily cap on Free Dictionary API fetches for modern-defs we don't have
# yet (D-DICT-4). Conservative; raise once observed.
MODERN_FETCH_DAILY_CAP=5000

# ───────────────────────────────────────────────────────────────────────────
# Phase 6 — Thummim cross-read
# ───────────────────────────────────────────────────────────────────────────

# Nightly snapshot of stewards.thummim_entries from pg-ai-stewards into
# 1828's own thummim_entries_cache (D-BE-THM).
THUMMIM_SYNC_ENABLED=false

# Source URL — depends on how pg-ai-stewards exposes the data. If we go
# postgres_fdw later, this becomes the upstream DSN. For the v1 nightly
# snapshot path, this is an HTTPS endpoint on stewards-ui.
# THUMMIM_SOURCE_URL=

# ───────────────────────────────────────────────────────────────────────────
# Future — pgvector + LM Studio embeddings (NOT used in v1 backend)
# ───────────────────────────────────────────────────────────────────────────

# When pgvector arrives, this points at LM Studio running on the Dokploy
# host. Per D-LP-1, LM Studio is reserved for EMBEDDINGS ONLY — render
# uses opencode-go/zen / OpenAI / OpenRouter via the BYOK path above.
# Locally on Windows: http://host.docker.internal:1234/v1
# On Linux Dokploy host: see the host-network tunnel configuration
# LM_STUDIO_BASE_URL=http://host.docker.internal:1234/v1
# LM_STUDIO_EMBEDDING_MODEL=text-embedding-nomic-embed-text-v1.5
