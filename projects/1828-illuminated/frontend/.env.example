# Frontend env (Vite). Variables MUST be prefixed `VITE_` to be exposed
# to the bundle. Copy to .env (gitignored) for local dev overrides.

# Base URL for the i1828 backend API.
#   - In production / inside the compose stack: leave unset (or `/api`).
#     The nginx sidecar reverse-proxies same-origin to the backend.
#   - For `npm run dev` against the compose stack on host 8083: set to
#     `http://localhost:8083/api`.
VITE_API_BASE_URL=/api
