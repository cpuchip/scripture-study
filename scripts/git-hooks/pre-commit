#!/bin/bash
# Phase 5d (Phase C.3): re-seed substrate when intent.yaml or
# .spec/covenant.yaml changes.
#
# Activated by symlink:
#   ln -s ../../scripts/git-hooks/pre-commit .git/hooks/pre-commit
# (Or by copy if symlinks aren't an option in the dev env.)
#
# If the dev container isn't running, the hook prints a warning and
# allows the commit to proceed — the seed can be re-run manually
# via:
#   docker exec pg-ai-stewards-dev psql -U stewards -d stewards \
#     -c "SELECT stewards.seed_intents_from_yaml(pg_read_file('/tmp/intent.yaml'));"
# (after docker cp-ing the YAML file in).

set -e

CHANGED=$(git diff --cached --name-only)
CONTAINER="pg-ai-stewards-dev"

container_running() {
    docker ps --format '{{.Names}}' 2>/dev/null | grep -q "^${CONTAINER}$"
}

reseed_intent() {
    if ! container_running; then
        echo "pre-commit: $CONTAINER not running; skipping intent re-seed."
        echo "  (manual: docker cp intent.yaml $CONTAINER:/tmp/ && psql -c \"SELECT stewards.seed_intents_from_yaml(pg_read_file('/tmp/intent.yaml'));\")"
        return 0
    fi
    echo "pre-commit: intent.yaml changed — reseeding stewards.intents"
    docker cp intent.yaml "${CONTAINER}:/tmp/intent.yaml" >/dev/null
    docker exec "${CONTAINER}" psql -U stewards -d stewards -tAc \
        "SELECT stewards.seed_intents_from_yaml(pg_read_file('/tmp/intent.yaml'));" \
        | sed 's/^/  intent_id=/'
}

reseed_covenant() {
    if ! container_running; then
        echo "pre-commit: $CONTAINER not running; skipping covenant re-seed."
        return 0
    fi
    echo "pre-commit: .spec/covenant.yaml changed — reseeding stewards.covenants"
    docker cp .spec/covenant.yaml "${CONTAINER}:/tmp/covenant.yaml" >/dev/null
    docker exec "${CONTAINER}" psql -U stewards -d stewards -tAc \
        "SELECT stewards.seed_covenant_from_yaml(pg_read_file('/tmp/covenant.yaml'));" \
        | sed 's/^/  covenant_id=/'
}

if echo "$CHANGED" | grep -qE '^intent\.yaml$'; then
    reseed_intent
fi

if echo "$CHANGED" | grep -qE '^\.spec/covenant\.yaml$'; then
    reseed_covenant
fi

# ---------------------------------------------------------------------
# Batch G.4.3 — materialize substrate's pending file writes.
#
# Drains stewards.pending_file_writes via stewards-cli materialize-writes.
# Files materialize into the working tree BEFORE the commit completes,
# so the newly-written files are NOT automatically staged — git status
# will show them after the commit and they'll be included in the NEXT
# commit (Michael's choice on staging keeps a human in the loop on what
# gets versioned).
#
# Skips gracefully if container is down or the CLI binary is missing.
# ---------------------------------------------------------------------

materialize_writes() {
    if ! container_running; then
        echo "pre-commit: $CONTAINER not running; skipping materialize-writes."
        return 0
    fi

    # Find the CLI binary. Look in canonical project bin/ first.
    local cli=""
    local repo_root
    repo_root="$(git rev-parse --show-toplevel)"
    for candidate in \
        "${repo_root}/projects/pg-ai-stewards/bin/stewards-cli.exe" \
        "${repo_root}/projects/pg-ai-stewards/bin/stewards-cli" \
        "${repo_root}/bin/stewards-cli.exe" \
        "${repo_root}/bin/stewards-cli"
    do
        if [ -x "$candidate" ]; then
            cli="$candidate"
            break
        fi
    done
    if [ -z "$cli" ] && command -v stewards-cli >/dev/null 2>&1; then
        cli="stewards-cli"
    fi
    if [ -z "$cli" ]; then
        echo "pre-commit: stewards-cli not found; skipping materialize-writes."
        echo "  (build: cd projects/pg-ai-stewards/cmd/stewards-cli && go build -o ../../bin/stewards-cli.exe .)"
        return 0
    fi

    # Quick check: any pending rows? If not, no output noise.
    local count
    count=$(docker exec "${CONTAINER}" psql -U stewards -d stewards -tAc \
        "SELECT count(*) FROM stewards.pending_file_writes WHERE materialized_at IS NULL" 2>/dev/null || echo "0")
    if [ "$count" = "0" ]; then
        return 0
    fi

    echo "pre-commit: $count pending file write(s); materializing"
    STEWARDS_DSN="${STEWARDS_DSN:-postgres://stewards:stewards@localhost:55433/stewards?sslmode=disable}" \
        "$cli" materialize-writes --repo-root "$(git rev-parse --show-toplevel)" 2>&1 \
        | sed 's/^/  /'
}

materialize_writes

exit 0
