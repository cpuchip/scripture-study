becoming-mcp.log
becoming.db*
scripts/becoming/becoming.exe

# Local secrets — never commit. .env.example is the committed shape.
.env
.env.*
!.env.example
!.env.*.example

# External things like github repos to ignore
external_context/

# things to just not check in
/private/

# Client-private pipeline drops — vivint outputs belong in /private/vivint/ (moved
# 2026-06-17). The reflect-steward/research pipelines materialize via the shared
# per-pipeline templates (plans/<slug>, research/<slug>), so a vivint run can still
# land a file in a public dir; this is the hard safety net — never commit it.
/plans/vivint-*
/research/vivint-*
/study/daily-digest/vivint-*

