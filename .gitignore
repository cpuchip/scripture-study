# Go build artifacts
scripts/gospel-library/gospel-library
scripts/gospel-library/gospel-library.exe
scripts/gospel-library/gospel-downloader.exe
scripts/publish/publish.exe
scripts/yt-mcp/yt-mcp
scripts/yt-mcp/yt-mcp.exe
